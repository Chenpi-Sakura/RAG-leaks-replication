# =================================================================
# RAG-leaks 复现 - LLM 配置模板
# -----------------------------------------------------------------
# 用法：cp .env.example .env  →  填入真实 key  →  python main.py
# .env 已 .gitignore；本文件进 git 留作模板
# =================================================================

# 必选：后端类型
# 取值: echo | openai | vllm-server | vllm-local
LLM_KIND=openai

# ----- 生成参数（所有后端通用；复现实验必锁这套） -----
LLM_MAX_NEW_TOKENS=128
LLM_TEMPERATURE=0.0
LLM_TOP_P=1.0

# ----- vLLM 显存占用比例（仅 LLM_KIND=vllm-local 生效） -----
# 同卡共享 embedder 时建议 0.7-0.85（embedder 也要 ~0.7GB）
# 单独 vLLM 时可 0.9
LLM_GPU_MEM_UTIL=0.85

# ----- 远程 API 模式（LLM_KIND=openai/vllm-server/ollama/tgi） -----
# OpenAI 官方：LLM_BASE_URL 留空
# vLLM server: LLM_BASE_URL=http://localhost:8000/v1  LLM_API_KEY=EMPTY
# Ollama:      LLM_BASE_URL=http://localhost:11434/v1 LLM_API_KEY=EMPTY
# 智谱 GLM:    LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# DeepSeek:    LLM_BASE_URL=https://api.deepseek.com/v1
# Kimi:        LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# 也支持用 OPENAI_API_KEY 兜底
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# chat 模板：raw | llama3 | mistral | chatml | auto
# auto = 让 HF tokenizer.apply_chat_template 处理（transformers >=4.40 支持）
LLM_CHAT=raw

# 是否多模态（content 支持 image_url 字段）
LLM_MULTIMODAL=false

# ----- 本地 vLLM 库模式（LLM_KIND=vllm-local） -----
# LLM_PATH=Qwen/Qwen2-VL-7B-Instruct
# LLM_CHAT=auto
# LLM_MAX_LEN=4096
# LLM_MULTIMODAL=auto                       # auto | true | false

